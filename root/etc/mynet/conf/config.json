{
    "server_config": {
        "api_base_url": "https://api.mynet.club/api/v1",
        "timeout": 30,
        "retry_count": 3
    },
    "downloads": {
        "apps_index_url": "https://download.mynet.club/apps.json"
    },
    "gnb": {
        "gnb_root": "/etc/mynet/driver/gnb",
        "gnb_bin_path": "/etc/mynet/driver/gnb/bin/gnb",
        "system_gnb_path": "/usr/sbin/gnb",
        "use_system_gnb": false
    }
}
